@article{fletcherImpactsPredatorAbundance2013,
  title = {Impacts of Predator Abundance on Red Grouse {{Lagopus}} Lagopus Scotica during a Period of Experimental Predator Control},
  author = {Fletcher, Kathy and Hoodless, Andrew N. and Baines, David},
  date = {2013},
  journaltitle = {Wildlife Biology},
  volume = {19},
  number = {3},
