% --------------------------------------------------------------------
% CODE LISTINGS  (must load before hyperref)
% --------------------------------------------------------------------
\usepackage{xcolor}                    % Must come before listings and hyperref

\definecolor{darkblue}{HTML}{1A4B8C}
\definecolor{customgreen}{rgb}{0,0.6,0}
\definecolor{customgray}{rgb}{0.5,0.5,0.5}
\definecolor{custommauve}{rgb}{0.6,0,0.8}
\definecolor{backcolour}{rgb}{0.95,0.95,0.92}

\usepackage{listings}

\lstset{
    language         = R,
    basicstyle       = \ttfamily\tiny,
    breaklines       = true,
    commentstyle     = \color{customgreen},
    backgroundcolor  = \color{backcolour},
    firstnumber      = 1,
    frame            = single,
    keepspaces       = true,
    keywordstyle     = \color{blue},
    numbers          = left,
    numbersep        = 10pt,
    numberstyle      = \tiny\color{customgray},
    rulecolor        = \color{black},
    showspaces       = false,
    showstringspaces = false,
    showtabs         = false,
    stepnumber       = 1,
    stringstyle      = \color{custommauve},
    tabsize          = 2,
}

% Add JAGS as an alias for R highlighting
\lstdefinelanguage{JAGS}[]{R}{
    morekeywords={for, in, model, dunif, dlogis, dnorm, dgamma,
            dmulti, dpois, dbern, dbeta, step, logit, log,
            sum, exp, abs, max, min, loggam},
    sensitive    = true,
}

% --------------------------------------------------------------------
% COLOR + HYPERLINKS  (after listings)
% --------------------------------------------------------------------
\usepackage[
    colorlinks=true,
    citecolor=darkblue,
    linkcolor=darkblue,
    urlcolor=darkblue
]{hyperref}

% --------------------------------------------------------------------
% REFERENCES (BIBLATEX)
% --------------------------------------------------------------------
\usepackage[
    backend=biber,
    style=authoryear,
    natbib=true,
    giveninits=true,
    uniquename=false,
    maxcitenames=2,
    maxbibnames=99,
    date=year,
    doi=true,
    url=false,
    isbn=false
]{biblatex}

\DefineBibliographyStrings{english}{andothers = {et al.}}
\renewbibmacro{in:}{}           % Remove "In:" in articles

